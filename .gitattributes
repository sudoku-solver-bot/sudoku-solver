# Auto detect text files and perform LF normalization
* text=auto

# Source code - force LF
*.kt text eol=lf
*.java text eol=lf
*.js text eol=lf
*.vue text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Configuration files - force LF
.gitattributes text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf
.dockerignore text eol=lf
.env.example text eol=lf
*.config text eol=lf

# Windows scripts - force CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files - don't touch
*.jar binary
*.war binary
*.ear binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.node binary

# Gradle wrapper (binary JAR)
gradle/wrapper/gradle-wrapper.jar binary
